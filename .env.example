# 选择模型: dashscope (阿里千问) 或 hunyuan (腾讯混元)
LLM_PROVIDER=dashscope

# 阿里云百炼平台 DashScope (当 LLM_PROVIDER=dashscope 时需要)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 腾讯混元 (当 LLM_PROVIDER=hunyuan 时需要)
HUNYUAN_API_KEY=your_hunyuan_api_key_here

# Knot 智能体 (当 provider 选择 knot 时需要)
KNOT_AGENT_ID=your_knot_agent_id_here
KNOT_API_TOKEN=your_knot_api_token_here
KNOT_API_USER=your_enterprise_wechat_name
